{
  "name": "@tdreyno/fizz",
  "version": "7.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdreyno/fizz.git"
  },
  "funding": "https://github.com/sponsors/tdreyno",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "fizz": "./dist/cli.cjs"
  },
  "license": "Hippocratic-2.1",
  "engines": {
    "node": ">= 20"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.js",
      "require": "./dist/test.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist && rm -rf .turbo && rm -rf node_modules",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "build": "tsdown",
    "dev": "npm run build -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:npm": "bash bin/test-npm-version",
    "visualize:loading-machine": "npm run build && node ./dist/cli.cjs visualize --source ./src/loadingMachine/index.ts --format text --format svg --output-dir ./src/loadingMachine",
    "visualize:loading-machine:check": "npm run visualize:loading-machine && git diff --exit-code -- ./src/loadingMachine/visualization.txt ./src/loadingMachine/visualization.svg"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tsconfig": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.11.2",
    "@types/serialize-javascript": "^5.0.4",
    "eslint": "^9.39.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "serialize-javascript": "^7.0.4",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "ts-morph": "^28.0.0"
  }
}
