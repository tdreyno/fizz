{
  "name": "@tdreyno/fizz-react",
  "version": "7.3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdreyno/fizz.git"
  },
  "funding": "https://github.com/sponsors/tdreyno",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "Hippocratic-2.1",
  "engines": {
    "node": ">= 20"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist && rm -rf .turbo && rm -rf node_modules",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "build": "tsdown",
    "dev": "npm run build -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand"
  },
  "dependencies": {
    "@tdreyno/fizz": "*"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tsconfig": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.11.2",
    "@types/react": "^19.2.5",
    "eslint": "^9.39.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.0",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  }
}
